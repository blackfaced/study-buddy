# Node
node_modules/
*.log
npm-debug.log*
.DS_Store

# Runtime data (SQLite is shared between mcp-server and HTTP server)
data/*.db
data/*.db-shm
data/*.db-wal

# Secrets / local TLS
.env
.env.local
*.pem
server.cert
server.key

# Mavis scratch (per-feature working notes; see docs/agents/issue-tracker.md)
.scratch/

# Git worktrees (feature/fix branches live here, not in main checkout)
.worktrees/

# Local CI workflow (kept on disk for inspection; the official one must be
# added via the GitHub web UI because `gh` doesn't have the `workflow` scope).
.github/
